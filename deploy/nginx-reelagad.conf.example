# Host nginx: proxy reelagad.com (HTTP and HTTPS) to your app on port 8443.
# Copy this to your server and enable it — see README below.
#
# On the server (e.g. 88.222.245.88):
#   1. sudo cp nginx-reelagad.conf.example /etc/nginx/sites-available/reelagad.com
#   2. sudo ln -s /etc/nginx/sites-available/reelagad.com /etc/nginx/sites-enabled/
#   3. Remove or rename the default site if it takes precedence:
#      sudo rm /etc/nginx/sites-enabled/default   # or mv default default.bak
#   4. For HTTPS: obtain certs (e.g. certbot --nginx -d reelagad.com -d www.reelagad.com)
#      then uncomment the 443 server block and the 80→443 redirect below.
#   5. sudo nginx -t && sudo systemctl reload nginx
#
# Ensure DNS: reelagad.com and www.reelagad.com A records → your server IP (88.222.245.88).

# Optional: redirect HTTP to HTTPS (uncomment when using the 443 block)
# server {
# 	listen 80;
# 	listen [::]:80;
# 	server_name reelagad.com www.reelagad.com;
# 	return 301 https://$server_name$request_uri;
# }

server {
	listen 80;
	listen [::]:80;
	server_name reelagad.com www.reelagad.com;

	location / {
		proxy_pass http://127.0.0.1:8443;
		proxy_http_version 1.1;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_read_timeout 60s;
		proxy_connect_timeout 60s;
		proxy_send_timeout 60s;
	}
}

